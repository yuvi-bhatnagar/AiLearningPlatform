{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=AiLearningDb;User Id=sa;Password=YOUR_SA_PASSWORD;TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "YOUR_JWT_SECRET_MIN_32_CHARS",
    "Issuer": "AiLearningPlatform",
    "Audience": "AiLearningPlatformUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AiSettings": {
    "Provider": "Gemini",
    "Model": "gemini-1.5-flash",
    "ApiKey": "YOUR_GEMINI_API_KEY"
  },
  "AdminSeed": {
    "Username": "admin",
    "Email": "admin@ailearning.dev",
    "Password": "YOUR_ADMIN_PASSWORD"
  }
}
