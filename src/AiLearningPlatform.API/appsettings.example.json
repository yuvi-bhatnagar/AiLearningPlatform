{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=AiLearningDb;User Id=YOUR_USER;Password=YOUR_PASSWORD;TrustServerCertificate=True;",
    "RedisConnection": "YOUR_REDIS_SERVER"
  },
  "JwtSettings": {
    "Secret": "YOUR_JWT_SECRET_MIN_32_CHARS",
    "Issuer": "AiLearningPlatform",
    "Audience": "AiLearningPlatformUsers",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AiSettings": {
    "Provider": "Gemini",
    "Model": "gemini-1.5-flash",
    "ApiKey": "YOUR_GEMINI_API_KEY"
  },
  "AdminSeed": {
    "Username": "admin",
    "Email": "admin@yourdomain.com",
    "Password": "YOUR_ADMIN_PASSWORD"
  }
}